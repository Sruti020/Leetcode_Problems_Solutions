class Solution {
    public void moveZeroes(int[] nums) {
        int cnt=0;
        int idx=0;
        for(int i=0;i<nums.length;i++){
            if(nums[i]!=0){
                nums[idx]=nums[i];
                idx++;
            }
            else{
                cnt++;
            }
        }
        for(int i=0;i<cnt;i++){
            nums[idx++]=0;
        }
    }
}
